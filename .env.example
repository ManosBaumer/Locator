# Supabase (production) — set SUPABASE_DB_PASSWORD, then run scripts/import-mcdonalds-checkpoint.ps1
SUPABASE_PROJECT_REF=ycfvmdehdotogbyrpvdm
SUPABASE_DB_PASSWORD=

# Local Docker (default)
DATABASE_URL=postgresql+asyncpg://locater:locater@db:5432/locater
SYNC_DATABASE_URL=postgresql+psycopg://locater:locater@db:5432/locater

# Supabase (production) — replace [PASSWORD] and [PROJECT_REF]
# Direct connection (ingestion, migrations):
# DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
# SYNC_DATABASE_URL=postgresql+psycopg://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
# Transaction pooler (API runtime, port 6543):
# DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

POSTGRES_USER=locater
POSTGRES_PASSWORD=locater
POSTGRES_DB=locater
AMAP_API_KEY=
ADMIN_API_KEY=change-me
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
NEXT_PUBLIC_MAP_TILE_URL=https://tiles.openfreemap.org/styles/liberty
